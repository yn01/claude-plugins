{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yoheinakanishi/Dev/claude-plugins/plugins/dev-forge/hooks/session-start.sh"
          }
        ],
        "description": "Notify unread message count on session start"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yoheinakanishi/Dev/claude-plugins/plugins/dev-forge/hooks/stop-hook.sh"
          }
        ],
        "description": "Warn about active contracts and update agent status on exit"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yoheinakanishi/Dev/claude-plugins/plugins/dev-forge/hooks/post-tool-use-hook.sh"
          }
        ],
        "description": "Detect task abandonment and prompt re-engagement"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yoheinakanishi/Dev/claude-plugins/plugins/dev-forge/hooks/session-end.sh"
          }
        ],
        "description": "Prompt learnings recording after iteration completion"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yoheinakanishi/Dev/claude-plugins/plugins/dev-forge/hooks/scope-check.sh"
          }
        ],
        "description": "Block out-of-scope file modifications"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yoheinakanishi/Dev/claude-plugins/plugins/dev-forge/hooks/pre-tool-use-hook.sh"
          }
        ],
        "description": "Validate communication rules before message send"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yoheinakanishi/Dev/claude-plugins/plugins/dev-forge/hooks/pre-compact.sh"
          }
        ],
        "description": "Persist agent state to SQLite before context compaction"
      }
    ]
  }
}
