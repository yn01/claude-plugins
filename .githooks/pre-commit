#!/usr/bin/env bash
# pre-commit: enforce version bump in both plugin README and root README
# when any file under plugins/<name>/ is staged.

STAGED=$(git diff --cached --name-only)
ROOT_README="README.md"

# Collect plugin names that have staged non-README files
CHANGED_PLUGINS=$(echo "$STAGED" \
  | grep '^plugins/' \
  | grep -v '^plugins/[^/]*/README\.md$' \
  | sed 's|^plugins/\([^/]*\)/.*|\1|' \
  | sort -u)

errors=0

for plugin in $CHANGED_PLUGINS; do
  plugin_readme="plugins/$plugin/README.md"

  # ── 1. Plugin README must be staged ──────────────────────────────────────
  if ! echo "$STAGED" | grep -q "^${plugin_readme}$"; then
    echo "❌  $plugin: $plugin_readme is not staged."
    echo "    Bump the version and stage $plugin_readme before committing."
    errors=$((errors + 1))
    continue
  fi

  # ── 2. Plugin README version must have changed ───────────────────────────
  NEW_VER=$(git show ":${plugin_readme}" 2>/dev/null \
    | grep -oE '### v[0-9]+\.[0-9]+\.[0-9]+' | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')
  OLD_VER=$(git show "HEAD:${plugin_readme}" 2>/dev/null \
    | grep -oE '### v[0-9]+\.[0-9]+\.[0-9]+' | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')

  if [ -z "$NEW_VER" ]; then
    echo "❌  $plugin: could not detect version in staged $plugin_readme."
    errors=$((errors + 1))
    continue
  fi

  if [ "$NEW_VER" = "$OLD_VER" ]; then
    echo "❌  $plugin: version is still v$OLD_VER in $plugin_readme — bump it before committing."
    errors=$((errors + 1))
    continue
  fi

  # ── 3. Root README must be staged ────────────────────────────────────────
  if ! echo "$STAGED" | grep -q "^${ROOT_README}$"; then
    echo "❌  $plugin: bumped to v$NEW_VER but root $ROOT_README is not staged."
    echo "    Update the $plugin entry in root README.md to v$NEW_VER."
    errors=$((errors + 1))
    continue
  fi

  # ── 4. Root README must show the new version ─────────────────────────────
  ROOT_VER=$(git show ":${ROOT_README}" 2>/dev/null \
    | grep -oE "\[${plugin}\].*\`v[0-9]+\.[0-9]+\.[0-9]+\`" \
    | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)

  if [ "$ROOT_VER" != "$NEW_VER" ]; then
    echo "❌  $plugin: root README.md shows v${ROOT_VER:-?}, expected v$NEW_VER."
    echo "    Update the $plugin entry in root README.md to v$NEW_VER."
    errors=$((errors + 1))
    continue
  fi

  echo "✅  $plugin v$NEW_VER — both READMEs updated."
done

[ $errors -gt 0 ] && exit 1
exit 0
